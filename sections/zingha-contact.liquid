{% comment %} Z!ngha — Contact page {% endcomment %}
<section class="bg-z-cream py-20 lg:py-28" aria-labelledby="contact-heading">
  <div class="z-container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20">

      {%- comment -%} Left: info {%- endcomment -%}
      <div class="lg:col-span-4" data-fm="fade-left">
        <p class="z-label mb-5">{{ section.settings.label | default: 'Contacto' }}</p>
        <h1 id="contact-heading" class="font-serif text-4xl lg:text-5xl font-light text-z-charcoal leading-[1.1] mb-6 text-balance">
          {{ section.settings.heading | default: 'Hablemos.' }}
        </h1>
        <p class="body-sm mb-10 max-w-xs leading-relaxed">
          {{ section.settings.description | default: 'Estamos aquí para responder tus preguntas sobre productos, pedidos o cualquier otra cosa.' }}
        </p>

        <div class="space-y-6">

          {%- if section.settings.email != blank -%}
            <div class="flex items-start gap-4">
              <div class="mt-0.5 flex-shrink-0 text-z-sage" aria-hidden="true">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
                </svg>
              </div>
              <div>
                <p class="font-sans text-[11px] uppercase tracking-widest text-z-muted mb-1">Correo</p>
                <a href="mailto:{{ section.settings.email }}" class="font-sans text-sm text-z-charcoal hover:text-z-sage transition-colors">
                  {{ section.settings.email }}
                </a>
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.whatsapp != blank -%}
            <div class="flex items-start gap-4">
              <div class="mt-0.5 flex-shrink-0 text-z-sage" aria-hidden="true">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
                </svg>
              </div>
              <div>
                <p class="font-sans text-[11px] uppercase tracking-widest text-z-muted mb-1">WhatsApp</p>
                <a href="https://wa.me/{{ section.settings.whatsapp | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" rel="noopener noreferrer" class="font-sans text-sm text-z-charcoal hover:text-z-sage transition-colors">
                  {{ section.settings.whatsapp }}
                </a>
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.hours != blank -%}
            <div class="flex items-start gap-4">
              <div class="mt-0.5 flex-shrink-0 text-z-sage" aria-hidden="true">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
              </div>
              <div>
                <p class="font-sans text-[11px] uppercase tracking-widest text-z-muted mb-1">Horario</p>
                <p class="font-sans text-sm text-z-charcoal">{{ section.settings.hours }}</p>
              </div>
            </div>
          {%- endif -%}

        </div>

        {%- comment -%} Social links {%- endcomment -%}
        {%- if section.settings.instagram != blank or section.settings.tiktok != blank -%}
          <div class="mt-10 pt-8 border-t border-z-sand/50">
            <p class="font-sans text-[11px] uppercase tracking-widest text-z-muted mb-4">Síguenos</p>
            <div class="flex gap-4">
              {%- if section.settings.instagram != blank -%}
                <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener noreferrer" class="text-z-muted hover:text-z-charcoal transition-colors" aria-label="Instagram">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              {%- endif -%}
              {%- if section.settings.tiktok != blank -%}
                <a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener noreferrer" class="text-z-muted hover:text-z-charcoal transition-colors" aria-label="TikTok">
                  <svg class="w-5 h-5" viewBox="0 0 50 50" fill="currentColor"><path d="M41 4H9C6.243 4 4 6.243 4 9v32c0 2.757 2.243 5 5 5h32c2.757 0 5-2.243 5-5V9c0-2.757-2.243-5-5-5zm-3.994 18.323a8.836 8.836 0 0 1-5.983-2.33v10.537a7.607 7.607 0 1 1-6.389-7.52v4.238a3.377 3.377 0 1 0 2.389 3.282V10.073h4a8.855 8.855 0 0 0 5.983 7.668v4.582z"/></svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>

      {%- comment -%} Right: contact form {%- endcomment -%}
      <div class="lg:col-span-8" data-fm="fade-right">
        {% form 'contact', id: 'z-contact-form' %}

          {%- if form.posted_successfully? -%}
            <div class="py-16 text-center" aria-live="polite">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-z-sage/10 mb-6 text-z-sage" aria-hidden="true">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
                </svg>
              </div>
              <h2 class="font-serif text-3xl font-light text-z-charcoal mb-3">Mensaje enviado.</h2>
              <p class="body-sm max-w-sm mx-auto">Te responderemos en un plazo de 24 horas hábiles. ¡Gracias por escribirnos!</p>
            </div>
          {%- else -%}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6">

              <div class="sm:col-span-1">
                <label for="contact-name" class="font-sans text-[11px] uppercase tracking-widest text-z-muted block mb-2">
                  Nombre <span aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="contact-name"
                  name="contact[name]"
                  autocomplete="name"
                  required
                  placeholder="Tu nombre completo"
                  class="w-full bg-transparent border-b border-z-sand focus:border-z-charcoal text-z-charcoal placeholder-z-sand font-sans text-sm py-3 outline-none transition-colors duration-200">
              </div>

              <div class="sm:col-span-1">
                <label for="contact-email" class="font-sans text-[11px] uppercase tracking-widest text-z-muted block mb-2">
                  Correo electrónico <span aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="contact-email"
                  name="contact[email]"
                  autocomplete="email"
                  required
                  placeholder="tu@correo.com"
                  class="w-full bg-transparent border-b border-z-sand focus:border-z-charcoal text-z-charcoal placeholder-z-sand font-sans text-sm py-3 outline-none transition-colors duration-200">
              </div>

              <div class="sm:col-span-2">
                <label for="contact-subject" class="font-sans text-[11px] uppercase tracking-widest text-z-muted block mb-2">
                  Asunto
                </label>
                <div class="relative">
                  <select
                    id="contact-subject"
                    name="contact[subject]"
                    class="w-full appearance-none bg-transparent border-b border-z-sand focus:border-z-charcoal text-z-charcoal font-sans text-sm py-3 pr-8 outline-none transition-colors duration-200 cursor-pointer">
                    <option value="Pedido">Sobre mi pedido</option>
                    <option value="Producto">Información de productos</option>
                    <option value="Devolución">Devoluciones</option>
                    <option value="Colaboración">Colaboración / Prensa</option>
                    <option value="Otro">Otro</option>
                  </select>
                  <div class="pointer-events-none absolute right-0 top-3.5 text-z-muted" aria-hidden="true">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
                    </svg>
                  </div>
                </div>
              </div>

              <div class="sm:col-span-2">
                <div class="flex items-center justify-between mb-2">
                  <label for="contact-message" class="font-sans text-[11px] uppercase tracking-widest text-z-muted">
                    Mensaje <span aria-hidden="true">*</span>
                  </label>
                  <span id="char-count" class="font-sans text-[10px] text-z-sand" aria-live="polite">0 / 500</span>
                </div>
                <textarea
                  id="contact-message"
                  name="contact[body]"
                  rows="5"
                  required
                  maxlength="500"
                  placeholder="Cuéntanos en qué podemos ayudarte..."
                  class="w-full bg-transparent border-b border-z-sand focus:border-z-charcoal text-z-charcoal placeholder-z-sand font-sans text-sm py-3 outline-none transition-colors duration-200 resize-none"
                  oninput="document.getElementById('char-count').textContent = this.value.length + ' / 500'"></textarea>
              </div>

              {%- if form.errors -%}
                <div class="sm:col-span-2">
                  <p class="font-sans text-xs text-z-terra bg-z-terra/10 rounded px-3 py-2" role="alert">
                    {{ form.errors | default_errors }}
                  </p>
                </div>
              {%- endif -%}

              <div class="sm:col-span-2 pt-4">
                <button type="submit" class="btn-primary">
                  {{ section.settings.submit_text | default: 'Enviar mensaje' }}
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                  </svg>
                </button>
              </div>

            </div>

          {%- endif -%}

        {% endform %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Z!ngha Contacto",
  "settings": [
    { "type": "text",     "id": "label",       "label": "Etiqueta",         "default": "Contacto" },
    { "type": "text",     "id": "heading",     "label": "Titular",          "default": "Hablemos." },
    { "type": "textarea", "id": "description", "label": "Descripción",      "default": "Estamos aquí para responder tus preguntas sobre productos, pedidos o cualquier otra cosa." },
    { "type": "text",     "id": "email",       "label": "Correo de contacto" },
    { "type": "text",     "id": "whatsapp",    "label": "WhatsApp (+52...)" },
    { "type": "text",     "id": "hours",       "label": "Horario de atención", "default": "Lun–Vie, 9am–6pm (Ciudad de México)" },
    { "type": "url",      "id": "instagram",   "label": "URL Instagram" },
    { "type": "url",      "id": "tiktok",      "label": "URL TikTok" },
    { "type": "text",     "id": "submit_text", "label": "Texto del botón",  "default": "Enviar mensaje" }
  ],
  "presets": [{ "name": "Z!ngha Contacto" }]
}
{% endschema %}
