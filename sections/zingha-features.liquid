{% comment %} Z!ngha — Value Props / 3 Columns {% endcomment %}
<section class="bg-z-cream py-20 lg:py-28 border-t border-b border-z-sand/50" aria-labelledby="features-heading">
  <div class="z-container">

    {%- if section.settings.heading != blank -%}
      <div class="text-center mb-14" data-fm="fade-up">
        <p class="z-label mb-4">{{ section.settings.label | default: 'Por qué Z!ngha' }}</p>
        <h2 id="features-heading" class="heading-lg text-balance">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 lg:gap-16" data-fm="stagger">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
        {%- when 'feature' -%}
          <div class="flex flex-col items-center sm:items-start text-center sm:text-left" data-fm-child {{ block.shopify_attributes }}>

            {%- if block.settings.image != blank -%}
              <div class="mb-6 overflow-hidden rounded-card aspect-4/3 w-full" data-fm="fade-in">
                {{ block.settings.image | image_url: width: 600 | image_tag:
                    class: 'w-full h-full object-cover object-center',
                    loading: 'lazy',
                    alt: block.settings.image.alt | default: block.settings.title,
                    widths: '300,600',
                    sizes: '(min-width:640px) 33vw, 100vw' }}
              </div>
            {%- endif -%}

            {%- comment -%} Icon — thin line SVGs {%- endcomment -%}
            {%- unless block.settings.image != blank -%}
            <div class="mb-6 h-10 w-10 flex items-center justify-center text-z-sage" aria-hidden="true">
              {%- case block.settings.icon -%}
              {%- when 'leaf' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-10 h-10">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
                </svg>
              {%- when 'hand' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-10 h-10">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.05 4.575a1.575 1.575 0 1 0-3.15 0v3m3.15-3v-1.5a1.575 1.575 0 0 1 3.15 0v1.5m-3.15 0 .075 5.925m3.075.75V4.575m0 0a1.575 1.575 0 0 1 3.15 0V15M6.9 7.575a1.575 1.575 0 1 0-3.15 0v8.175a6.75 6.75 0 0 0 6.75 6.75h2.018a5.25 5.25 0 0 0 3.712-1.538l1.732-1.732a5.25 5.25 0 0 0 1.538-3.712l.003-2.024a.668.668 0 0 1 .198-.471 1.575 1.575 0 1 0-2.228-2.228 3.818 3.818 0 0 0-1.12 2.687M6.9 7.575V12m6.27 4.318A4.49 4.49 0 0 1 16.35 15"/>
                </svg>
              {%- when 'clock' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-10 h-10">
                  <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/>
                </svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-10 h-10">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
                </svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-10 h-10">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-10 h-10">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
                </svg>
              {%- endcase -%}
            </div>
            {%- endunless -%}

            <span class="z-divider mb-5 sm:mx-0 mx-auto"></span>

            <h3 class="font-serif text-xl font-normal text-z-charcoal mb-3 leading-snug">
              {{ block.settings.title }}
            </h3>
            <p class="body-sm max-w-xs">{{ block.settings.description }}</p>
          </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Z!ngha Features",
  "settings": [
    { "type": "text", "id": "label",   "label": "Etiqueta",  "default": "Por qué Z!ngha" },
    { "type": "text", "id": "heading", "label": "Titular" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen opcional (sustituye al ícono)" },
        {
          "type": "select", "id": "icon", "label": "Ícono",
          "options": [
            { "value": "leaf",  "label": "Hoja" },
            { "value": "hand",  "label": "Mano" },
            { "value": "clock", "label": "Reloj" },
            { "value": "shield","label": "Escudo" },
            { "value": "star",  "label": "Estrella" }
          ], "default": "leaf"
        },
        { "type": "text",     "id": "title",       "label": "Título",      "default": "Beneficio" },
        { "type": "textarea", "id": "description", "label": "Descripción", "default": "Descripción breve del beneficio principal." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Z!ngha Features",
      "blocks": [
        { "type": "feature", "settings": { "icon": "leaf",  "title": "Ingredientes 100% naturales",         "description": "Sin sintéticos, sin conservadores. Aceites esenciales con trazabilidad de origen garantizada." } },
        { "type": "feature", "settings": { "icon": "hand",  "title": "Diseño ergonómico certificado",       "description": "Pensado para caber en cualquier bolsillo. Discreto, ligero y a prueba de fugas." } },
        { "type": "feature", "settings": { "icon": "clock", "title": "Efecto en menos de 60 segundos",     "description": "La vía olfativa es la más rápida al sistema límbico. Siente el cambio con cada inhalación." } }
      ]
    }
  ]
}
{% endschema %}
