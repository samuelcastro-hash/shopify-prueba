{% comment %} Z!ngha — Editorial / Brand Story (50/50 split) {% endcomment %}
<section class="bg-z-cream overflow-hidden" aria-labelledby="editorial-heading">
  <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[560px] lg:min-h-[640px]">

    {%- comment -%} Image — left or right per setting {%- endcomment -%}
    {%- assign img_order = '' -%}
    {%- assign text_order = '' -%}
    {%- if section.settings.layout == 'text_first' -%}
      {%- assign img_order = 'lg:order-2' -%}
      {%- assign text_order = 'lg:order-1' -%}
    {%- endif -%}

    <div class="relative overflow-hidden {{ img_order }} bg-z-beige" data-fm="fade-in">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1000 | image_tag:
            class: 'w-full h-full object-cover object-center absolute inset-0',
            loading: 'lazy',
            alt: section.settings.image.alt | default: 'Z!ngha',
            widths: '600,900,1000',
            sizes: '(min-width:1024px) 50vw, 100vw' }}
      {%- else -%}
        <div class="absolute inset-0 flex items-center justify-center text-z-sand/40">
          <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Z"/>
          </svg>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Text {%- endcomment -%}
    <div class="flex items-center {{ text_order }} px-8 py-16 lg:px-20 lg:py-24 xl:px-28" data-fm="fade-right">
      <div class="max-w-md">
        {%- if section.settings.label != blank -%}
          <p class="z-label mb-5">{{ section.settings.label }}</p>
          <span class="z-divider mb-8"></span>
        {%- endif -%}

        <h2 id="editorial-heading" class="heading-xl mb-6 text-balance">
          {{ section.settings.heading | default: 'Diseñado para tu momento.' }}
        </h2>

        {%- if section.settings.body != blank -%}
          <div class="prose prose-sm font-sans font-light text-z-muted leading-relaxed mb-10 [&_strong]:font-medium [&_strong]:text-z-charcoal">
            {{ section.settings.body }}
          </div>
        {%- else -%}
          <p class="body-lg mb-10">
            Nacimos de la búsqueda de calma en un mundo acelerado. Cada Z!ngha es el resultado de formulas de aromaterapia clínica encapsuladas en un objeto de diseño que cabe en tu bolsillo.
          </p>
        {%- endif -%}

        <a href="{{ section.settings.cta_url | default: '/pages/sobre-nosotros' }}"
           class="btn-ghost">
          {{ section.settings.cta_text | default: 'Conoce nuestra historia' }}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Z!ngha Editorial",
  "settings": [
    { "type": "image_picker", "id": "image",   "label": "Imagen editorial" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [
        { "value": "image_first", "label": "Imagen izquierda" },
        { "value": "text_first",  "label": "Texto izquierda" }
      ], "default": "image_first"
    },
    { "type": "text",     "id": "label",    "label": "Etiqueta",  "default": "Nuestra Historia" },
    { "type": "text",     "id": "heading",  "label": "Titular",   "default": "Diseñado para tu momento." },
    { "type": "richtext", "id": "body",     "label": "Texto",     "default": "<p>Nacimos de la búsqueda de calma en un mundo acelerado. Cada Z!ngha es el resultado de fórmulas de aromaterapia clínica encapsuladas en un objeto de diseño que cabe en tu bolsillo.</p>" },
    { "type": "url",      "id": "cta_url",  "label": "URL del CTA" },
    { "type": "text",     "id": "cta_text", "label": "Texto del CTA", "default": "Conoce nuestra historia" }
  ],
  "presets": [{ "name": "Z!ngha Editorial" }]
}
{% endschema %}
