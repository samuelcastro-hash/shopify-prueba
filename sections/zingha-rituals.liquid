{% comment %} Z!ngha — Rituales / Usos (Tabs) {% endcomment %}
<section class="bg-z-charcoal py-20 lg:py-28" aria-labelledby="rituals-heading">
  <div class="z-container">

    <div class="text-center mb-14" data-fm="fade-up">
      <p class="z-label-sage mb-4">{{ section.settings.label | default: 'Rituales de uso' }}</p>
      <h2 id="rituals-heading" class="heading-lg text-z-cream text-balance max-w-lg mx-auto">
        {{ section.settings.heading | default: 'Un Z!ngha para cada momento de tu día' }}
      </h2>
    </div>

    {%- comment -%} Tab buttons {%- endcomment -%}
    <div class="flex items-center justify-center gap-8 mb-12 overflow-x-auto pb-2 scrollbar-none" role="tablist" aria-label="Rituales" data-fm="fade-up">
      {%- for block in section.blocks -%}
        {%- if block.type == 'ritual' -%}
          <button
            type="button"
            class="ritual-tab font-sans text-sm tracking-widest uppercase text-z-sand/60 pb-1 whitespace-nowrap flex-shrink-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-z-sage rounded-[1px]{%- if forloop.first %} active{%- endif %}"
            role="tab"
            aria-selected="{%- if forloop.first %}true{%- else %}false{%- endif %}"
            aria-controls="ritual-panel-{{ forloop.index }}"
            id="ritual-tab-{{ forloop.index }}"
            data-tab="{{ forloop.index }}"
            {{ block.shopify_attributes }}>
            {{ block.settings.title | default: 'Ritual' }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Tab panels {%- endcomment -%}
    <div class="relative" data-rituals-container>
      {%- for block in section.blocks -%}
        {%- if block.type == 'ritual' -%}
          <div
            class="ritual-panel grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center{%- if forloop.first %} active{%- endif %}"
            id="ritual-panel-{{ forloop.index }}"
            role="tabpanel"
            aria-labelledby="ritual-tab-{{ forloop.index }}"
            {{ block.shopify_attributes }}>

            {%- comment -%} Image {%- endcomment -%}
            <div class="relative overflow-hidden rounded-card bg-z-beige/10 aspect-4/3 lg:aspect-square" data-ritual-img>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 900 | image_tag:
                    class: 'w-full h-full object-cover object-center',
                    loading: 'lazy',
                    alt: block.settings.image.alt | default: block.settings.title,
                    widths: '500,900',
                    sizes: '(min-width:1024px) 50vw, 100vw' }}
              {%- else -%}
                <div class="flex items-center justify-center h-full text-z-sand/20">
                  <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Z"/>
                  </svg>
                </div>
              {%- endif -%}

              {%- comment -%} Ritual number overlay {%- endcomment -%}
              <div class="absolute top-5 left-5" aria-hidden="true">
                <span class="font-serif text-7xl font-light text-z-cream/10 leading-none">0{{ forloop.index }}</span>
              </div>
            </div>

            {%- comment -%} Content {%- endcomment -%}
            <div class="flex flex-col justify-center" data-ritual-content>
              <span class="z-label-sage mb-5">{{ block.settings.moment | default: 'Ritual' }}</span>
              <h3 class="font-serif text-3xl lg:text-4xl font-light text-z-cream mb-5 leading-snug text-balance">
                {{ block.settings.heading | default: block.settings.title }}
              </h3>
              <p class="body-sm text-z-sand/70 mb-8 max-w-md leading-relaxed">
                {{ block.settings.description | default: 'Descripción del ritual.' }}
              </p>
              {%- if block.settings.product != blank -%}
                <a href="{{ block.settings.product.url }}" class="btn-primary-light self-start">
                  {{ block.settings.cta_text | default: 'Ver producto' }}
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                  </svg>
                </a>
              {%- elsif block.settings.cta_url != blank -%}
                <a href="{{ block.settings.cta_url }}" class="btn-primary-light self-start">
                  {{ block.settings.cta_text | default: 'Ver producto' }}
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Z!ngha Rituales",
  "settings": [
    { "type": "text", "id": "label",   "label": "Etiqueta", "default": "Rituales de uso" },
    { "type": "text", "id": "heading", "label": "Titular",  "default": "Un Z!ngha para cada momento de tu día" }
  ],
  "blocks": [
    {
      "type": "ritual",
      "name": "Ritual",
      "settings": [
        { "type": "text",         "id": "title",       "label": "Nombre del tab",    "default": "Mañana" },
        { "type": "text",         "id": "moment",      "label": "Etiqueta momento",  "default": "Ritual Matutino" },
        { "type": "text",         "id": "heading",     "label": "Titular del panel", "default": "Empieza el día con intención." },
        { "type": "textarea",     "id": "description", "label": "Descripción",       "default": "Comienza tu mañana con energía y claridad mental. El aroma de Z!ngha activa tu sistema en segundos, sin cafeína ni azúcar." },
        { "type": "image_picker", "id": "image",       "label": "Imagen" },
        { "type": "product",      "id": "product",     "label": "Producto relacionado" },
        { "type": "url",          "id": "cta_url",     "label": "URL del CTA (si no hay producto)" },
        { "type": "text",         "id": "cta_text",    "label": "Texto del CTA",     "default": "Ver producto" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Z!ngha Rituales",
      "blocks": [
        {
          "type": "ritual",
          "settings": {
            "title": "Mañana",
            "moment": "Ritual Matutino",
            "heading": "Empieza el día con intención.",
            "description": "Activa tu mente antes del café. Una o dos inhalaciones de Surge son suficientes para despertar tu concentración y sentar el tono del día sin estimulantes artificiales."
          }
        },
        {
          "type": "ritual",
          "settings": {
            "title": "Trabajo",
            "moment": "Ritual de Enfoque",
            "heading": "Concentración sin distracciones.",
            "description": "En sesiones largas o reuniones exigentes, Z!ngha Surge te mantiene alerta y presente. Discreto en cualquier escritorio, efectivo en cada inhalación."
          }
        },
        {
          "type": "ritual",
          "settings": {
            "title": "Noche",
            "moment": "Ritual Nocturno",
            "heading": "Desconecta con calma.",
            "description": "Al terminar el día, Z!ngha Mango transita tu mente hacia el descanso. El sistema límbico responde al aroma en segundos, preparando el cuerpo para dormir profundo."
          }
        },
        {
          "type": "ritual",
          "settings": {
            "title": "Viaje",
            "moment": "Ritual en Movimiento",
            "heading": "Tu ritual donde vayas.",
            "description": "Diseñado para caber en cualquier bolsillo, Z!ngha Slim es el compañero ideal para aeropuertos, reuniones fuera de la ciudad o escapadas de fin de semana."
          }
        }
      ]
    }
  ]
}
{% endschema %}
