{% comment %} Z!ngha — Featured Products {% endcomment %}
<section class="bg-z-charcoal py-20 lg:py-28" aria-labelledby="products-heading">
  <div class="z-container">

    {%- comment -%} Header {%- endcomment -%}
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12" data-fm="fade-up">
      <div>
        <p class="z-label-sage mb-4">{{ section.settings.label | default: 'Nuestra Colección' }}</p>
        <h2 id="products-heading" class="heading-lg text-z-cream text-balance">
          {{ section.settings.heading | default: 'Encuentra tu Z!ngha perfecto' }}
        </h2>
      </div>
      {%- if section.settings.show_view_all -%}
        <a href="{{ section.settings.collection.url | default: routes.all_products_collection_url }}"
           class="btn-primary-light flex-shrink-0 self-start sm:self-auto py-2.5 px-6">
          Ver toda la colección
        </a>
      {%- endif -%}
    </div>

    {%- assign products = section.settings.collection.products -%}
    {%- if products != blank -%}

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        {%- for product in products limit: section.settings.products_limit -%}
          <article class="z-product-card group" data-fm="fade-up" style="transition-delay: {{ forloop.index0 | times: 0.08 }}s">

            {%- comment -%} Image {%- endcomment -%}
            <a href="{{ product.url }}" class="block relative overflow-hidden rounded-card bg-z-beige/20 aspect-3/4 mb-4">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 600 | image_tag:
                    class: 'z-product-img w-full h-full object-cover object-center',
                    loading: 'lazy',
                    alt: product.featured_image.alt | default: product.title,
                    widths: '300,600',
                    sizes: '(min-width:1024px) 25vw, 50vw' }}
              {%- else -%}
                <div class="flex items-center justify-center h-full text-z-sand">
                  <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Z"/>
                  </svg>
                </div>
              {%- endif -%}

              {%- comment -%} Badges {%- endcomment -%}
              <div class="absolute top-3 left-3 flex flex-col gap-1.5">
                {%- if product.compare_at_price > product.price -%}
                  <span class="font-sans text-[10px] font-semibold uppercase tracking-wider bg-z-terra text-white px-2 py-0.5 rounded-[1px]">
                    &minus;{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}%
                  </span>
                {%- endif -%}
                {%- if product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}
                  <span class="font-sans text-[10px] font-semibold uppercase tracking-wider bg-z-cream text-z-charcoal px-2 py-0.5 rounded-[1px]">Bestseller</span>
                {%- endif -%}
                {%- if product.tags contains 'nuevo' or product.tags contains 'Nuevo' or product.tags contains 'new' -%}
                  <span class="font-sans text-[10px] font-semibold uppercase tracking-wider bg-z-sage text-white px-2 py-0.5 rounded-[1px]">Nuevo</span>
                {%- endif -%}
              </div>

              {%- comment -%} Quick-add hover overlay {%- endcomment -%}
              <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-luxury p-3">
                {%- if product.available -%}
                  {%- if product.variants.size == 1 -%}
                    <form action="/cart/add" method="post">
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="btn-primary w-full justify-center py-2.5 text-[12px]">
                        Añadir al carrito
                      </button>
                    </form>
                  {%- else -%}
                    <a href="{{ product.url }}" class="btn-primary w-full justify-center py-2.5 text-[12px]">Ver opciones</a>
                  {%- endif -%}
                {%- endif -%}
              </div>
            </a>

            {%- comment -%} Info {%- endcomment -%}
            <div>
              <a href="{{ product.url }}" class="block">
                <h3 class="font-serif text-lg font-normal text-z-cream leading-snug mb-1 hover:text-z-sand transition-colors">
                  {{ product.title }}
                </h3>
              </a>
              <p class="body-sm text-z-sand/60 mb-2 line-clamp-1">
                {{ product.description | strip_html | truncate: 60 }}
              </p>
              <div class="flex items-baseline gap-2">
                <span class="font-sans text-base font-semibold text-z-cream">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="font-sans text-sm text-z-sand/50 line-through">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
            </div>

          </article>
        {%- endfor -%}
      </div>

    {%- else -%}
      <p class="text-z-sand/60 text-center py-12 font-sans text-sm">
        Asigna una colección en el editor para mostrar productos.
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Z!ngha Products",
  "settings": [
    { "type": "text",       "id": "label",          "label": "Etiqueta",                "default": "Nuestra Colección" },
    { "type": "text",       "id": "heading",         "label": "Titular",                 "default": "Encuentra tu Z!ngha perfecto" },
    { "type": "collection", "id": "collection",      "label": "Colección" },
    { "type": "range",      "id": "products_limit",  "label": "Número de productos",     "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "checkbox",   "id": "show_view_all",   "label": "Mostrar enlace 'Ver todo'", "default": true }
  ],
  "presets": [{ "name": "Z!ngha Products" }]
}
{% endschema %}
