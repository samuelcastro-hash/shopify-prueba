{% comment %} Z!ngha — FAQ Accordion {% endcomment %}
<section class="bg-z-cream py-20 lg:py-28" aria-labelledby="faq-heading">
  <div class="z-container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20{% if section.settings.image != blank %} lg:items-start{% endif %}">

      {%- comment -%} Left: heading (sticky on desktop) {%- endcomment -%}
      <div class="lg:col-span-4 lg:sticky lg:top-24" data-fm="fade-left">
        <p class="z-label mb-4">{{ section.settings.label | default: 'Preguntas frecuentes' }}</p>
        <h2 id="faq-heading" class="heading-lg text-balance mb-6">
          {{ section.settings.heading | default: '¿Tienes dudas? Las respondemos.' }}
        </h2>
        <p class="body-sm mb-8">{{ section.settings.description | default: 'Si no encuentras lo que buscas, nuestro equipo está listo para ayudarte.' }}</p>
        <a href="{{ section.settings.contact_url | default: '/pages/contacto' }}" class="btn-secondary inline-flex">
          Hablar con nosotros
        </a>
      </div>

      {%- comment -%} Right: accordion {%- endcomment -%}
      <div class="lg:col-span-8{% if section.settings.image != blank %} lg:grid lg:grid-cols-2 lg:gap-20 lg:items-start{% endif %}" data-fm="fade-right">
        {%- if section.settings.image != blank -%}
          <div class="hidden lg:block relative overflow-hidden rounded-card aspect-4/5 sticky top-24" data-fm="fade-right">
            {{ section.settings.image | image_url: width: 800 | image_tag:
                class: 'w-full h-full object-cover object-center',
                loading: 'lazy',
                alt: section.settings.image.alt | default: 'Z!ngha FAQ',
                widths: '400,800',
                sizes: '45vw' }}
          </div>
        {%- endif -%}
        <div class="divide-y divide-z-sand" role="list">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
            {%- when 'faq_item' -%}
              {%- assign id = 'faq-' | append: forloop.index -%}
              <div class="faq-item py-1" role="listitem" {{ block.shopify_attributes }}>
                <button type="button"
                        class="faq-trigger w-full flex items-center justify-between gap-6 py-6 text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-z-sage rounded"
                        aria-expanded="false"
                        aria-controls="{{ id }}-panel"
                        id="{{ id }}-btn">
                  <span class="font-serif text-xl font-normal text-z-charcoal leading-snug">
                    {{ block.settings.question }}
                  </span>
                  <span class="flex-shrink-0 w-6 h-6 text-z-muted" aria-hidden="true">
                    <svg class="faq-icon-plus w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                    </svg>
                    <svg class="faq-icon-minus w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15"/>
                    </svg>
                  </span>
                </button>
                <div class="faq-content" id="{{ id }}-panel" role="region" aria-labelledby="{{ id }}-btn">
                  <div class="pb-7 pr-10">
                    <div class="body-lg prose prose-sm max-w-none [&_a]:text-z-sage [&_a:hover]:text-z-sage-dark [&_strong]:text-z-charcoal [&_strong]:font-medium">
                      {{ block.settings.answer }}
                    </div>
                  </div>
                </div>
              </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
        {%- comment -%} End accordion list — closes inner grid col when image is set {%- endcomment -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Z!ngha FAQ",
  "settings": [
    { "type": "text",     "id": "label",       "label": "Etiqueta",    "default": "Preguntas frecuentes" },
    { "type": "text",     "id": "heading",     "label": "Titular",     "default": "¿Tienes dudas? Las respondemos." },
    { "type": "textarea",    "id": "description", "label": "Descripción", "default": "Si no encuentras lo que buscas, nuestro equipo está listo para ayudarte." },
    { "type": "image_picker", "id": "image",       "label": "Imagen lateral (opcional)" },
    { "type": "url",           "id": "contact_url", "label": "URL de contacto" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Pregunta",
      "settings": [
        { "type": "text",     "id": "question", "label": "Pregunta", "default": "¿Cuál es tu pregunta?" },
        { "type": "richtext", "id": "answer",   "label": "Respuesta", "default": "<p>Aquí va tu respuesta.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Z!ngha FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "¿Qué es Z!ngha y cómo funciona?",           "answer": "<p>Z!ngha es un inhalador personal de aromaterapia con aceites esenciales 100% naturales. Al inhalar, los compuestos activan el sistema límbico, mejorando el estado de ánimo, reduciendo la ansiedad o aumentando la energía según la fórmula elegida.</p>" } },
        { "type": "faq_item", "settings": { "question": "¿Contiene nicotina o es perjudicial?",       "answer": "<p>No. Z!ngha no contiene nicotina, tabaco ni sustancias adictivas. Solo aceites esenciales de origen natural, sin synthéticos ni conservadores.</p>" } },
        { "type": "faq_item", "settings": { "question": "¿Cuánto tiempo dura cada inhalador?",        "answer": "<p>Con uso normal (10–15 inhalaciones diarias), dura entre 2 y 4 semanas. Los modelos dobles tienen el doble de capacidad.</p>" } },
        { "type": "faq_item", "settings": { "question": "¿Envían a todo México?",                     "answer": "<p>Sí, enviamos a toda la República Mexicana. Los pedidos se procesan en 1–2 días hábiles y la entrega toma entre 3–7 días hábiles con número de rastreo incluido.</p>" } },
        { "type": "faq_item", "settings": { "question": "¿Cuál es su política de devoluciones?",      "answer": "<p>Si el producto llegó dañado, contáctanos dentro de los 7 días posteriores a la recepción. Por higiene, los inhaladores usados no son elegibles para devolución, pero siempre encontramos una solución.</p>" } }
      ]
    }
  ]
}
{% endschema %}
