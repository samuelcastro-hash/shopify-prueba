{% comment %} Z!ngha — Track Order Page {% endcomment %}

<section class="bg-z-charcoal min-h-screen flex items-center py-24 lg:py-32" aria-labelledby="track-heading">
  <div class="z-container-narrow w-full">

    <div class="text-center mb-14" data-fm="fade-up">
      <p class="z-label-sage mb-5">{{ section.settings.label | default: 'Mis pedidos' }}</p>
      <span class="z-divider mx-auto mb-8"></span>
      <h1 id="track-heading" class="font-serif text-4xl lg:text-5xl font-light text-z-cream mb-5 text-balance">
        {{ section.settings.heading | default: 'Rastrea tu pedido.' }}
      </h1>
      <p class="font-sans text-sm font-light text-z-sand/70 max-w-md mx-auto">
        {{ section.settings.description | default: 'Ingresa tu número de rastreo para ver el estado de tu envío en tiempo real.' }}
      </p>
    </div>

    <div class="bg-z-cream rounded-card p-8 lg:p-12 max-w-xl mx-auto" data-fm="fade-up">

      <div class="mb-8">
        <label for="z-track-input"
               class="block font-sans text-[11px] uppercase tracking-[0.2em] text-z-muted mb-3">
          Número de rastreo
        </label>
        <div class="flex gap-3">
          <input
            type="text"
            id="YQNum"
            name="track-order-number"
            maxlength="50"
            placeholder="Ej. MX123456789MX"
            class="flex-1 bg-z-beige border border-z-sand rounded-btn px-4 py-3 font-sans text-sm text-z-charcoal placeholder-z-sand focus:outline-none focus:border-z-charcoal transition-colors"
          >
          <button
            type="button"
            onclick="doTrack()"
            class="btn-primary flex-shrink-0">
            {{ section.settings.button_label | default: 'Rastrear' }}
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
          </button>
        </div>
      </div>

      <div id="YQContainer" class="min-h-[40px]"></div>

      {%- if section.settings.help_text != blank -%}
        <p class="mt-8 pt-6 border-t border-z-sand/50 font-sans text-xs text-z-muted text-center">
          {{ section.settings.help_text }}
          {%- if section.settings.contact_url != blank -%}
            <a href="{{ section.settings.contact_url }}"
               class="text-z-charcoal underline underline-offset-4 ml-1 hover:text-z-sage transition-colors">
              Contáctanos
            </a>
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} Order status links {%- endcomment -%}
    <div class="mt-10 text-center" data-fm="fade-up">
      <a href="{{ routes.account_url }}"
         class="font-sans text-xs text-z-sand/50 hover:text-z-sand transition-colors underline underline-offset-4">
        Ver historial de pedidos en mi cuenta
      </a>
    </div>

  </div>
</section>

<script type="text/javascript" src="//www.17track.net/externalcall.js"></script>
<script type="text/javascript">
  function doTrack() {
    var num = document.getElementById("YQNum").value;
    if (num === "") {
      alert("Por favor ingresa un número de rastreo.");
      return;
    }
    YQV5.trackSingle({
      YQ_ContainerId: "YQContainer",
      YQ_Height: 560,
      YQ_Fc: "0",
      YQ_Lang: "es",
      YQ_Num: num
    });
  }
</script>

{% schema %}
{
  "name": "Z!ngha Rastrear Pedido",
  "settings": [
    { "type": "text",     "id": "label",        "label": "Etiqueta",              "default": "Mis pedidos" },
    { "type": "text",     "id": "heading",      "label": "Titular",               "default": "Rastrea tu pedido." },
    { "type": "textarea", "id": "description",  "label": "Descripción",           "default": "Ingresa tu número de rastreo para ver el estado de tu envío en tiempo real." },
    { "type": "text",     "id": "button_label", "label": "Texto del botón",       "default": "Rastrear" },
    { "type": "text",     "id": "help_text",    "label": "Texto de ayuda",        "default": "¿No encuentras tu número de rastreo?" },
    { "type": "url",      "id": "contact_url",  "label": "URL de contacto" }
  ],
  "presets": [{ "name": "Z!ngha Rastrear Pedido" }]
}
{% endschema %}
