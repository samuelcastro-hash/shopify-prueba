{% comment %} Z!ngha — Testimonials (minimal, no photos) {% endcomment %}
<section class="bg-z-beige py-20 lg:py-28" aria-labelledby="testimonials-heading">
  <div class="z-container">

    <div class="text-center mb-14" data-fm="fade-up">
      <p class="z-label mb-4">{{ section.settings.label | default: 'Testimonios' }}</p>
      <h2 id="testimonials-heading" class="heading-lg text-balance max-w-lg mx-auto">
        {{ section.settings.heading | default: 'Lo que dicen quienes nos eligen' }}
      </h2>
    </div>

    {%- comment -%} Stars summary {%- endcomment -%}
    <div class="flex items-center justify-center gap-3 mb-12" data-fm="fade-up">
      <div class="flex gap-1">
        {%- for i in (1..5) -%}
          <svg class="w-4 h-4 text-z-terra" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        {%- endfor -%}
      </div>
      <p class="font-sans text-sm font-medium text-z-charcoal">
        {{ section.settings.rating_summary | default: '4.9 / 5 · +350 reseñas verificadas' }}
      </p>
    </div>

    {%- comment -%} Testimonials grid {%- endcomment -%}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8" data-fm="stagger">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
        {%- when 'testimonial' -%}
          <blockquote class="bg-z-cream p-8 rounded-card flex flex-col gap-6" data-fm-child {{ block.shopify_attributes }}>
            <div class="flex gap-0.5" aria-label="{{ block.settings.rating }} de 5 estrellas">
              {%- assign stars = block.settings.rating | default: 5 -%}
              {%- for i in (1..5) -%}
                <svg class="w-3.5 h-3.5 {%- if i <= stars %} text-z-terra{%- else %} text-z-sand{%- endif %}" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              {%- endfor -%}
            </div>

            <p class="font-serif text-lg font-light text-z-charcoal leading-relaxed italic flex-1">
              "{{ block.settings.quote }}"
            </p>

            <footer class="flex items-center gap-3 pt-4 border-t border-z-sand/50">
              <div class="flex h-9 w-9 items-center justify-center rounded-full bg-z-beige font-serif text-sm font-normal text-z-charcoal flex-shrink-0" aria-hidden="true">
                {{ block.settings.name | slice: 0 | upcase }}
              </div>
              <div>
                <p class="font-sans text-sm font-medium text-z-charcoal">{{ block.settings.name }}</p>
                <p class="font-sans text-xs text-z-muted">{{ block.settings.location | default: 'México' }}</p>
              </div>
              {%- if block.settings.verified -%}
                <span class="ml-auto font-sans text-[10px] font-semibold uppercase tracking-wider text-z-sage">✓ Verificado</span>
              {%- endif -%}
            </footer>
          </blockquote>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} As-seen-on {%- endcomment -%}
    {%- if section.settings.show_logos -%}
      <div class="mt-16 pt-12 border-t border-z-sand" data-fm="fade-up">
        <p class="text-center font-sans text-[11px] uppercase tracking-[0.2em] text-z-muted mb-8">
          {{ section.settings.logos_label | default: 'Hablando de nosotros en' }}
        </p>
        <div class="flex items-center justify-center gap-10 sm:gap-16 flex-wrap">
          <div class="text-z-sand hover:text-z-muted transition-colors" aria-label="TikTok">
            <svg class="h-6" viewBox="0 0 50 50" fill="currentColor"><path d="M41 4H9C6.243 4 4 6.243 4 9v32c0 2.757 2.243 5 5 5h32c2.757 0 5-2.243 5-5V9c0-2.757-2.243-5-5-5zm-3.994 18.323a8.836 8.836 0 0 1-5.983-2.33v10.537a7.607 7.607 0 1 1-6.389-7.52v4.238a3.377 3.377 0 1 0 2.389 3.282V10.073h4a8.855 8.855 0 0 0 5.983 7.668v4.582z"/></svg>
          </div>
          <div class="text-z-sand hover:text-z-muted transition-colors" aria-label="Instagram">
            <svg class="h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Z!ngha Testimonios",
  "settings": [
    { "type": "text",     "id": "label",          "label": "Etiqueta",         "default": "Testimonios" },
    { "type": "text",     "id": "heading",         "label": "Titular",          "default": "Lo que dicen quienes nos eligen" },
    { "type": "text",     "id": "rating_summary",  "label": "Resumen calificación", "default": "4.9 / 5 · +350 reseñas verificadas" },
    { "type": "checkbox", "id": "show_logos",      "label": "Mostrar logos",    "default": true },
    { "type": "text",     "id": "logos_label",     "label": "Texto sobre logos","default": "Hablando de nosotros en" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        { "type": "text",     "id": "name",     "label": "Nombre",          "default": "Cliente" },
        { "type": "text",     "id": "location", "label": "Ciudad",          "default": "Ciudad de México" },
        { "type": "textarea", "id": "quote",    "label": "Cita",            "default": "Excelente producto." },
        { "type": "range",    "id": "rating",   "label": "Calificación",    "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "checkbox", "id": "verified", "label": "Compra verificada","default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Z!ngha Testimonios",
      "blocks": [
        { "type": "testimonial", "settings": { "name": "Mario C.",  "location": "Monterrey, NL",    "quote": "Llevo dos semanas usándolo y bajé mi consumo de vape a la mitad. Fácil de usar, discreto y efectivo. Lo recomiendo mucho.", "rating": 5 } },
        { "type": "testimonial", "settings": { "name": "Marta M.",  "location": "Ciudad de México", "quote": "Cuando mi amiga me explicó los beneficios no sabía qué esperar, pero me ha solucionado la vida en muchos aspectos. Estoy encantada.", "rating": 5 } },
        { "type": "testimonial", "settings": { "name": "Ramón T.",  "location": "Guadalajara, JAL", "quote": "Lo pedí como alternativa para controlar la ansiedad de dejar el cigarro. El aroma es relajante y muy práctico de usar.", "rating": 5 } }
      ]
    }
  ]
}
{% endschema %}
