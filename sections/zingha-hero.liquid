{% comment %} Z!ngha — Hero (full-screen, luxury minimal) {% endcomment %}

<style>
  /* ── Inhaler cap-reveal animation ── */
  .z-inhaler-stage {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* Glow layer behind the product */
  .z-inhaler-stage::before {
    content: '';
    position: absolute;
    inset: 10% 5%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      rgba(245, 180, 60, 0.30) 0%,
      rgba(245, 180, 60, 0.12) 45%,
      transparent 70%
    );
    filter: blur(32px);
    z-index: 0;
    animation: z-glow-pulse 5s ease-in-out infinite;
  }

  @keyframes z-glow-pulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.08); }
  }

  /* Shared image base */
  .z-inhaler-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
  }

  /* Open inhaler (with nozzles) — always behind */
  .z-inhaler-open {
    z-index: 1;
  }

  /* Closed inhaler (the "cap") — slides up and down */
  .z-inhaler-closed {
    z-index: 2;
    animation: z-cap-off 5.5s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    will-change: transform;
  }

  /*
   * 0–18%  : closed  (pause — cap on)
   * 18–40% : cap slides UP (uncapping)
   * 40–62% : open    (pause — nozzles revealed)
   * 62–84% : cap slides DOWN (recapping)
   * 84–100%: closed  (back to resting state)
   */
  @keyframes z-cap-off {
    0%,  18% { transform: translateY(0%); }
    40%, 60% { transform: translateY(-108%); }
    82%, 100%{ transform: translateY(0%); }
  }

  /* Gentle float on the whole stage */
  .z-inhaler-float {
    animation: z-float 6s ease-in-out infinite;
  }

  @keyframes z-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }

  /* ── Mobile product strip ── */
  .z-hero-product-mobile {
    position: relative;
    width: 220px;
    height: 260px;
    margin: 0 auto 2rem;
    overflow: hidden; /* clips the closed img as it slides off */
  }

  /* ── Desktop product pane ── */
  .z-hero-product-desktop {
    overflow: hidden; /* clips closed img as it slides off */
  }

  /* Fallback: single-image mode (no open image set) */
  .z-inhaler-single {
    z-index: 2;
  }
</style>

<section id="z-hero-wrap"
         class="relative min-h-screen flex items-end lg:items-center bg-z-cream overflow-hidden"
         aria-label="Hero">

  {%- comment -%} Background image {%- endcomment -%}
  {%- if section.settings.bg_image != blank -%}
    <div class="absolute inset-0" aria-hidden="true">
      {{ section.settings.bg_image | image_url: width: 2000 | image_tag:
          class: 'w-full h-full object-cover object-center',
          loading: 'eager',
          fetchpriority: 'high',
          alt: '',
          widths: '750,1200,1600,2000',
          sizes: '100vw' }}
      <div class="absolute inset-0 bg-gradient-to-t from-z-charcoal/30 via-z-charcoal/10 to-transparent lg:bg-gradient-to-r lg:from-z-cream/80 lg:via-z-cream/50 lg:to-transparent"></div>
    </div>
  {%- else -%}
    <div class="absolute inset-0 bg-z-beige" aria-hidden="true">
      <div class="absolute bottom-0 right-0 w-2/3 h-full bg-z-cream-dark/50" style="clip-path:polygon(15% 0%,100% 0%,100% 100%,0% 100%)"></div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Animated product — desktop ── {%- endcomment -%}
  {%- assign has_closed = section.settings.product_image_closed
      | default: section.settings.product_image -%}
  {%- assign has_open   = section.settings.product_image_open -%}

  {%- if has_closed != blank -%}
    <div class="z-hero-product-desktop hidden lg:block absolute right-0 top-0 h-full w-[42%] xl:w-[45%]"
         aria-hidden="true" data-fm="fade-right">
      <div class="z-inhaler-float w-full h-full">
        <div class="z-inhaler-stage">

          {%- if has_open != blank -%}
            {{- has_open | image_url: width: 900 | image_tag:
                class: 'z-inhaler-img z-inhaler-open drop-shadow-2xl',
                loading: 'eager',
                fetchpriority: 'high',
                alt: '',
                widths: '600,900',
                sizes: '45vw' -}}
          {%- endif -%}

          {{- has_closed | image_url: width: 900 | image_tag:
              class: 'z-inhaler-img z-inhaler-closed drop-shadow-2xl',
              loading: 'eager',
              fetchpriority: 'high',
              alt: '',
              widths: '600,900',
              sizes: '45vw' -}}

        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Content ── {%- endcomment -%}
  <div class="z-container relative z-10 w-full pb-16 pt-28 lg:py-0 lg:min-h-screen flex items-center">
    <div class="max-w-xl" data-fm="fade-up">

      {%- comment -%} ── Animated product — mobile (above the text) ── {%- endcomment -%}
      {%- if has_closed != blank -%}
        <div class="lg:hidden" aria-hidden="true">
          <div class="z-hero-product-mobile z-inhaler-float">
            <div class="z-inhaler-stage">

              {%- if has_open != blank -%}
                {{- has_open | image_url: width: 500 | image_tag:
                    class: 'z-inhaler-img z-inhaler-open drop-shadow-2xl',
                    loading: 'eager',
                    alt: '',
                    widths: '300,500',
                    sizes: '220px' -}}
              {%- endif -%}

              {{- has_closed | image_url: width: 500 | image_tag:
                  class: 'z-inhaler-img z-inhaler-closed drop-shadow-2xl',
                  loading: 'eager',
                  alt: '',
                  widths: '300,500',
                  sizes: '220px' -}}

            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.label != blank -%}
        <p class="z-label mb-5">{{ section.settings.label }}</p>
        <span class="z-divider mb-8"></span>
      {%- endif -%}

      <h1 class="heading-display mb-6 text-balance
                 {%- if section.settings.bg_image != blank %} text-white lg:text-z-charcoal{%- endif %}">
        {%- if section.settings.headline != blank -%}
          {{ section.settings.headline }}
        {%- else -%}
          Rituales de bienestar<br>
          <em>en la palma de tu mano.</em>
        {%- endif -%}
      </h1>

      <p class="body-lg max-w-sm mb-10
               {%- if section.settings.bg_image != blank %} text-white/70 lg:text-z-muted{%- endif %}">
        {{ section.settings.subheadline | default: 'Aromaterapia clínica en un inhalador de diseño. 100% natural, efecto en menos de 60 segundos.' }}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="{{ section.settings.primary_cta_url | default: routes.all_products_collection_url }}"
           class="btn-primary">
          {{ section.settings.primary_cta_text | default: 'Descubrir la Colección' }}
        </a>
        <a href="{{ section.settings.secondary_cta_url | default: '#rituales' }}"
           class="btn-ghost">
          {{ section.settings.secondary_cta_text | default: '¿Qué es la aromaterapia?' }}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
          </svg>
        </a>
      </div>

      {%- comment -%} Trust bar {%- endcomment -%}
      <div class="mt-14 flex items-center gap-6 flex-wrap">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
          {%- when 'trust_item' -%}
            <div class="flex items-center gap-2" {{ block.shopify_attributes }}>
              <svg class="w-4 h-4 text-z-sage flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
              </svg>
              <span class="font-sans text-xs font-medium text-z-muted
                          {%- if section.settings.bg_image != blank %} text-white/60 lg:text-z-muted{%- endif %}">
                {{ block.settings.text }}
              </span>
            </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} Scroll cue {%- endcomment -%}
  <div class="hidden lg:flex absolute bottom-10 left-1/2 -translate-x-1/2 flex-col items-center gap-2" aria-hidden="true">
    <span class="font-sans text-[10px] uppercase tracking-[0.2em] text-z-muted">Deslizar</span>
    <div class="h-10 w-px bg-z-sand animate-bounce origin-top"></div>
  </div>

</section>

{% schema %}
{
  "name": "Z!ngha Hero",
  "settings": [
    { "type": "image_picker", "id": "bg_image",              "label": "Imagen de fondo (lifestyle)" },
    { "type": "image_picker", "id": "product_image_closed",  "label": "Inhalador cerrado (tapa puesta)" },
    { "type": "image_picker", "id": "product_image_open",    "label": "Inhalador abierto (boquillas visibles)" },
    { "type": "image_picker", "id": "product_image",         "label": "Imagen del producto (fallback, si no hay las anteriores)" },
    { "type": "text",         "id": "label",                 "label": "Etiqueta superior",          "default": "Aromaterapia Premium" },
    { "type": "textarea",     "id": "headline",              "label": "Titular (dejar vacío para usar el predeterminado)" },
    { "type": "textarea",     "id": "subheadline",           "label": "Subtítulo",                  "default": "Aromaterapia clínica en un inhalador de diseño. 100% natural, efecto en menos de 60 segundos." },
    { "type": "url",          "id": "primary_cta_url",       "label": "URL CTA principal" },
    { "type": "text",         "id": "primary_cta_text",      "label": "Texto CTA principal",         "default": "Descubrir la Colección" },
    { "type": "url",          "id": "secondary_cta_url",     "label": "URL CTA secundario" },
    { "type": "text",         "id": "secondary_cta_text",    "label": "Texto CTA secundario",        "default": "¿Qué es la aromaterapia?" }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto", "default": "100% Natural" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Z!ngha Hero",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "Ingredientes naturales" } },
        { "type": "trust_item", "settings": { "text": "Sin nicotina" } },
        { "type": "trust_item", "settings": { "text": "Entrega en 3–5 días" } }
      ]
    }
  ]
}
{% endschema %}
